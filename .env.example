# Webhook configuration
WEBHOOK_SECRET=your-secret-key-here
WEBHOOK_PORT=5050
WEBHOOK_TARGET_URL=https://example.com/webhook
WEBHOOK_DB=webhooks.db

# SurrealDB (used in Docker; leave empty for SQLite fallback)
SURREALDB_URL=
SURREALDB_NS=captainhook
SURREALDB_DB=captainhook
SURREALDB_USER=root
SURREALDB_PASS=root

# Docker / Reverse Proxy
DOMAIN=localhost
ACME_EMAIL=
HTTP_PORT=80
HTTPS_PORT=443
